{
	"name": "stijnklomp-linting-formatting-config",
	"version": "7.0.4",
	"private": false,
	"description": "Linting and formatting configuration for Typescript projects using typescript-eslint.",
	"homepage": "https://github.com/stijnklomp/linting-formatting-config#readme",
	"bugs": {
		"url": "https://github.com/stijnklomp/linting-formatting-config/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com/stijnklomp/linting-formatting-config.git"
	},
	"license": "MIT",
	"author": "stijnklomp",
	"type": "module",
	"main": "./dist/index.js",
	"files": [
		"dist/**/*",
		".editorconfig",
		"sortJson.sh"
	],
	"scripts": {
		"build": "rm -rf dist && tsc -p declaration.tsconfig.json",
		"clean": "rm -rf $(find . -maxdepth 2 -type f -name '*.d.ts*')",
		"lint": "eslint --report-unused-disable-directives . --cache",
		"lint:fix": "./sortJson.sh && eslint --report-unused-disable-directives . --cache --fix",
		"prepare": "husky",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@typescript-eslint/parser": "^8.60.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-jest": "^29.15.2",
		"eslint-plugin-jsonc": "^3.2.0",
		"eslint-plugin-markdown": "^5.1.0",
		"eslint-plugin-package-json": "^1.3.0",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-yml": "^3.4.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"json-sort-cli": "^4.1.3",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"prettier-plugin-packagejson": "^3.0.2",
		"stylelint": "^17.12.0",
		"stylelint-config-prettier-scss": "^1.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"typedoc": "^0.28.19",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1"
	},
	"peerDependencies": {
		"@eslint/js": ">=10.x",
		"@typescript-eslint/parser": ">=8.x",
		"eslint": ">=10.x",
		"eslint-config-prettier": ">=9.x",
		"eslint-plugin-jest": ">=28.x",
		"eslint-plugin-jsonc": ">=3.x",
		"eslint-plugin-markdown": ">=5.x",
		"eslint-plugin-package-json": ">=1.x",
		"eslint-plugin-prettier": ">=5.x",
		"eslint-plugin-react": ">=7.x",
		"eslint-plugin-react-hooks": ">=5.x",
		"eslint-plugin-yml": ">=3.x",
		"globals": ">=16.x",
		"json-sort-cli": ">=4.x",
		"prettier": ">=3.x",
		"prettier-plugin-packagejson": ">=3.x",
		"stylelint": ">=16.x",
		"stylelint-config-prettier-scss": ">=1.x",
		"stylelint-config-standard-scss": ">=13.x",
		"typedoc": ">=0.x",
		"typescript": ">=6.x",
		"typescript-eslint": "^8.x"
	},
	"peerDependenciesMeta": {
		"@eslint/js": {
			"optional": true
		},
		"eslint-plugin-jest": {
			"optional": true
		},
		"eslint-plugin-markdown": {
			"optional": true
		},
		"eslint-plugin-react": {
			"optional": true
		},
		"eslint-plugin-react-hooks": {
			"optional": true
		},
		"globals": {
			"optional": true
		},
		"stylelint": {
			"optional": true
		},
		"stylelint-config-prettier-scss": {
			"optional": true
		},
		"stylelint-config-standard-scss": {
			"optional": true
		},
		"typedoc": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	}
}
